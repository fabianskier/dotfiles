# Ghostty configuration

# Theme
theme = catppuccin-mocha.conf

# Font
font-family = JetBrains Mono Nerd Font
font-size = 12

# Window
window-decoration = true
window-padding-x = 8
window-padding-y = 8

# Cursor
cursor-style = block
cursor-style-blink = true

# Scrollback
scrollback-limit = 10000

# Copy on select
copy-on-select = false
