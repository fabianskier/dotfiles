#!/bin/bash
# Sketchybar - Catppuccin Mocha + Aerospace

PLUGIN_DIR="$CONFIG_DIR/plugins"

BAR_COLOR=0xff1e1e2e
ACTIVE_BG=0xff89b4fa
ACTIVE_FG=0xff1e1e2e
TEXT=0xffcdd6f4
SUBTEXT=0xff45475a

##### Bar #####
sketchybar --bar \
  position=top \
  height=28 \
  color=$BAR_COLOR \
  padding_left=8 \
  padding_right=8 \
  shadow=off

##### Defaults #####
sketchybar --default \
  icon.font="JetBrainsMono Nerd Font:Bold:12.0" \
  label.font="JetBrainsMono Nerd Font:Regular:12.0" \
  icon.color=$SUBTEXT \
  label.drawing=off \
  icon.padding_left=6 \
  icon.padding_right=6 \
  background.corner_radius=4 \
  background.height=20 \
  background.drawing=off \
  padding_left=1 \
  padding_right=1

##### Aerospace events #####
sketchybar --add event aerospace_workspace_change
sketchybar --add event aerospace_monitor_change

# Workspaces 1-5 → monitor externo (display 1)
for sid in 1 2 3 4 5; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      display=1 \
      icon="$sid" \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# Workspaces 6-10 → laptop (display 2)
for sid in 6 7 8 9 10; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      display=2 \
      icon="$sid" \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

##### Right: solo clock #####
sketchybar \
  --add item clock right \
  --set clock \
    update_freq=10 \
    script="$PLUGIN_DIR/clock.sh" \
    icon.drawing=off \
    label.drawing=on \
    label.color=$SUBTEXT \
    label.font="JetBrainsMono Nerd Font:Regular:12.0" \
    background.drawing=off

sketchybar --update
